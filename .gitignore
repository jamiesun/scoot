# Zig build artifacts
/.zig-cache/
/zig-cache/
/zig-out/

# Compiled objects and binaries
*.o
*.obj
*.a
*.lib
*.so
*.dylib
*.dll
*.exe
*.pdb

# Coverage / profiling output
*.profraw
*.profdata
/coverage/
/kcov-output/

# Generated documentation site
/site/

# Local configuration and test state
/config.toml

# Playground keeps a committed test environment but ignores its runtime state
# and secrets via playground/.gitignore (data dirs, generated config, .env).

# Logs and temporary files
*.log
*.tmp
*.temp

# Audit/report output (project-audit, playground-eval, etc.)
/reports/

# Editor / IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS metadata
.DS_Store
Thumbs.db
