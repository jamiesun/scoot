# Scoot Playground — local environment overrides (committed template).
# shellcheck shell=sh
#
# Copy this file to playground/.env and fill in your values. playground/.env is
# gitignored: secrets and personal backend endpoints stay on your machine only.
#
# playground/scripts/env.sh sources playground/.env and regenerates the runtime
# playground/config.toml from playground/config.default.toml, applying the
# backend overrides below. Only set what you need; unset values keep the
# committed defaults in config.default.toml. `export` makes the values visible
# to scoot and the scripts (and keeps shellcheck SC2034 quiet).

# Required: the API token for your OpenAI-compatible backend. Scoot reads it from
# this environment variable (config.default.toml sets api_key_env to this name).
# The value is never written to config, audit logs, or sessions.
export SCOOT_PLAYGROUND_API_KEY=""

# Optional: override the committed backend defaults for your own endpoint.
# Leave unset to use config.default.toml (local Ollama on 127.0.0.1:11434).
# export SCOOT_PLAYGROUND_BASE_URL="https://your-host.example.com/openai/v1"
# export SCOOT_PLAYGROUND_MODEL="gpt-4o-mini"

# Optional: per-run knobs read by the scripts (not by scoot directly).
# export SCOOT_TASK_TIMEOUT_SEC=180
# export SCOOT_PLAYGROUND_MCP_HOST=127.0.0.1
# export SCOOT_PLAYGROUND_MCP_PORT=18799
